#:kivy 2.0
#:import os os

# Global navigation bar background macro style to ensure visual consistency
<NavBar@BoxLayout>:
    orientation: 'horizontal'
    size_hint_y: None
    height: dp(48)
    spacing: dp(6)
    padding: [dp(2), dp(2)]
    canvas.before:
        Color:
            rgba: (0.10, 0.12, 0.18, 0.6)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(12)]

<SelectableResultButton>:
    size_hint_y: None
    height: dp(52)
    text_size: self.width - dp(24), None
    halign: 'left'
    valign: 'center'
    on_release: app.root.get_screen('search_screen').select_result(root.result_index)
    background_color: (0, 0, 0, 0)
    bold: True
    font_size: '13sp'
    color: (1, 1, 1, 1) if self.state == 'normal' else (0.02, 0.03, 0.07, 1)
    canvas.before:
        Color:
            rgba: (0.1, 0.12, 0.18, 0.7) if self.state == 'normal' else (0.2, 0.83, 0.61, 1)
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [dp(10)]


# =========================================================================
# INTERFACE 1: THE MUSIC PLAYER SCREEN (Audio Deck Controls)
# =========================================================================
<PlayerScreen>:
    canvas.before:
        Color:
            rgba: (0.06, 0.07, 0.11, 1)
        Rectangle:
            size: self.size
            pos: self.pos
        Mesh:
            mode: 'triangle_fan'
            vertices:
                [
                self.x, self.y, 0, 0, 0.06, 0.07, 0.11, 1,
                self.right, self.y, 0, 0, 0.08, 0.12, 0.18, 1,
                self.right, self.top, 0, 0, 0.18, 0.12, 0.32, 1,
                self.x, self.top, 0, 0, 0.05, 0.22, 0.25, 1
                ]
            indices: [0, 1, 2, 3]

    BoxLayout:
        orientation: 'vertical'
        padding: dp(12)
        spacing: dp(12)

        # Header Title Banner
        BoxLayout:
            size_hint_y: None
            height: dp(44)
            canvas.before:
                Color:
                    rgba: (0.11, 0.31, 0.92, 0.8)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]
            Label:
                text: 'Music Audio Deck'
                halign: 'center'
                valign: 'center'
                text_size: self.width, self.height
                bold: True
                font_size: '15sp'
                color: (1, 1, 1, 1)

        # Dynamic Center Display Artwork Frame
        Image:
            source: root.background_image if root.background_image else "assets/images/dancing_lion.png"
            size_hint_y: 0.45
            allow_stretch: True
            keep_ratio: True
            canvas.before:
                Color:
                    rgba: (0.10, 0.12, 0.18, 0.4)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

        # Global Runtime Application Status Box
        BoxLayout:
            size_hint_y: None
            height: dp(34)
            padding: [dp(10), 0]
            canvas.before:
                Color:
                    rgba: (0.07, 0.16, 0.14, 0.6) if "playing" in root.status_text.lower() or "found" in root.status_text.lower() else (0.18, 0.12, 0.08, 0.6)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(8)]
            Label:
                text: root.status_text
                halign: 'left'
                valign: 'center'
                text_size: self.width, self.height
                font_size: '11sp'
                color: (0.2, 0.83, 0.61, 1) if "playing" in root.status_text.lower() or "found" in root.status_text.lower() else (0.95, 0.6, 0.2, 1)

        # Now Playing Tracking Controller Panel
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: None
            height: dp(76)
            spacing: dp(4)
            padding: dp(10)
            canvas.before:
                Color:
                    rgba: (0.12, 0.15, 0.24, 0.6)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

            Label:
                text: '♫ ' + root.current_track_title
                size_hint_y: None
                height: dp(20)
                halign: 'center'
                valign: 'middle'
                text_size: self.width, self.height
                bold: True
                font_size: '13sp'
                color: (0.2, 0.83, 0.61, 1)

            Slider:
                id: progress_slider
                min: 0
                max: root.progress_max
                value: root.progress_value
                size_hint_y: None
                height: dp(24)
                value_track: True
                value_track_color: (0.11, 0.31, 0.92, 1)
                on_touch_down: if self.collide_point(*args[1].pos): root.on_progress_slider_touch_down()
                on_touch_up: if getattr(root, '_is_seeking', False) and not self.collide_point(*args[1].pos): root.on_progress_slider_release(self.value)

            Label:
                id: progress_label
                text: root.progress_text
                size_hint_y: None
                height: dp(14)
                halign: 'center'
                valign: 'middle'
                text_size: self.width, self.height
                font_size: '11sp'
                color: (0.7, 0.75, 0.9, 0.9)

        # Music Control Grid Panel (Primary Playback Actions)
        GridLayout:
            cols: 4
            size_hint_y: None
            height: dp(46)
            spacing: dp(6)

            Button:
                text: '⏮ Prev'
                on_release: root.select_previous_result()
                background_color: (0, 0, 0, 0)
                bold: True
                font_size: '12sp'
                canvas.before:
                    Color:
                        rgba: (0.16, 0.20, 0.32, 0.8)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

            Button:
                text: '⏯ Play/Pause'
                on_release: root.pause_audio()
                background_color: (0, 0, 0, 0)
                bold: True
                font_size: '12sp'
                canvas.before:
                    Color:
                        rgba: (0.08, 0.48, 0.26, 0.9)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

            Button:
                text: '⏹ Stop'
                on_release: root.stop_audio()
                background_color: (0, 0, 0, 0)
                bold: True
                font_size: '12sp'
                canvas.before:
                    Color:
                        rgba: (0.72, 0.20, 0.20, 0.9)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

            Button:
                text: 'Next ⏭'
                on_release: root.select_next_result()
                background_color: (0, 0, 0, 0)
                bold: True
                font_size: '12sp'
                canvas.before:
                    Color:
                        rgba: (0.16, 0.20, 0.32, 0.8)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

        Widget: # Dynamic spacer pushing navigation down completely

        # Persistent App Switcher Tab bar
        NavBar:
            Button:
                text: '● Deck'
                bold: True
                color: (0.2, 0.83, 0.61, 1)
                background_color: (0, 0, 0, 0)
                canvas.before:
                    Color:
                        rgba: (0.11, 0.31, 0.92, 0.4)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]
            Button:
                text: 'Search Hub'
                background_color: (0, 0, 0, 0)
                on_release: root.manager.current = 'search_screen'
            Button:
                text: 'Developer'
                background_color: (0, 0, 0, 0)
                on_release: root.manager.current = 'developer_screen'


# =========================================================================
# INTERFACE 2: THE MUSIC SEARCH & BROWSE SCREEN (Online & Local)
# =========================================================================
<SearchScreen>:
    canvas.before:
        Color:
            rgba: (0.06, 0.07, 0.11, 1)
        Rectangle:
            size: self.size
            pos: self.pos
        Mesh:
            mode: 'triangle_fan'
            vertices:
                [
                self.x, self.y, 0, 0, 0.06, 0.07, 0.11, 1,
                self.right, self.y, 0, 0, 0.08, 0.12, 0.18, 1,
                self.right, self.top, 0, 0, 0.18, 0.12, 0.32, 1,
                self.x, self.top, 0, 0, 0.05, 0.22, 0.25, 1
                ]
            indices: [0, 1, 2, 3]

    BoxLayout:
        orientation: 'vertical'
        padding: dp(12)
        spacing: dp(10)

        # Input Search Module
        BoxLayout:
            size_hint_y: None
            height: dp(50)
            spacing: dp(8)
            padding: [dp(6), 0, 0, 0]
            canvas.before:
                Color:
                    rgba: (0.12, 0.15, 0.22, 0.5)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]

            TextInput:
                id: search_input
                text: root.search_query
                hint_text: 'Search online, local, or recommendations...'
                multiline: False
                on_text: root.search_query = self.text
                on_text_validate: root.on_search_button()
                background_color: (0, 0, 0, 0)
                hint_text_color: (0.5, 0.52, 0.6, 0.7)
                foreground_color: (1, 1, 1, 1)
                font_size: '14sp'
                padding_y: [self.height / 2 - (self.line_height / 2), 0]

            Button:
                text: 'Search'
                size_hint_x: None
                width: dp(100)
                on_release: root.on_search_button()
                background_color: (0, 0, 0, 0)
                bold: True
                font_size: '13sp'
                color: (1, 1, 1, 1)
                canvas.before:
                    Color:
                        rgba: (0.11, 0.31, 0.92, 1)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]

        # Play Random Songs Activation Bar
        Button:
            text: "🎲 Play Random Track"
            size_hint_y: None
            height: dp(40)
            background_color: (0, 0, 0, 0)
            bold: True
            font_size: '13sp'
            color: (1, 1, 1, 1)
            on_release: root.play_random_fallback_track()
            canvas.before:
                Color:
                    rgba: (0.12, 0.53, 0.34, 0.9)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(10)]

        # Dynamic Status Tracker Row
        Label:
            text: root.status_text
            size_hint_y: None
            height: dp(20)
            font_size: '11sp'
            halign: 'left'
            valign: 'center'
            text_size: self.width, self.height
            color: (0.2, 0.83, 0.61, 1) if "found" in root.status_text.lower() or "random" in root.status_text.lower() else (0.95, 0.6, 0.2, 1)

        # Search Results Panel Frame
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.42
            spacing: dp(4)
            padding: dp(6)
            canvas.before:
                Color:
                    rgba: (0.10, 0.13, 0.20, 0.5)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(14)]

            Label:
                text: f'Aggregated Libraries Results ({len(root.results)} tracks found)'
                size_hint_y: None
                height: dp(22)
                halign: 'left'
                valign: 'center'
                text_size: self.width, self.height
                bold: True
                font_size: '11sp'
                color: (0.6, 0.65, 0.8, 1)
                padding_x: dp(6)

            RecycleView:
                id: results_rv
                data: root.rv_data
                viewclass: 'SelectableResultButton'
                scroll_type: ['bars', 'content']
                bar_width: dp(4)
                RecycleBoxLayout:
                    default_size: None, dp(52)
                    default_size_hint: 1, None
                    size_hint_y: None
                    height: self.minimum_height
                    orientation: 'vertical'
                    spacing: dp(6)

        # Local Storage File system Explorer Deck
        BoxLayout:
            orientation: 'horizontal'
            size_hint_y: 0.38
            spacing: dp(10)

            BoxLayout:
                orientation: 'vertical'
                spacing: dp(4)
                padding: dp(4)
                canvas.before:
                    Color:
                        rgba: (0.10, 0.12, 0.18, 0.5)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(14)]

                BoxLayout:
                    size_hint_y: None
                    height: dp(36)
                    spacing: dp(4)
                    Button:
                        text: '💾 Storage'
                        on_release: root.on_browse_internal_memory()
                        background_color: (0, 0, 0, 0)
                        bold: True
                        font_size: '11sp'
                        canvas.before:
                            Color:
                                rgba: (0.16, 0.20, 0.32, 0.8)
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(8)]

                Label:
                    text: root.browse_path
                    size_hint_y: None
                    height: dp(16)
                    halign: 'left'
                    valign: 'middle'
                    text_size: self.width, self.height
                    font_size: '10sp'
                    color: (0.5, 0.6, 0.7, 1)
                    shorten: True
                    shorten_from: 'left'
                    padding_x: dp(4)

                FileChooserListView:
                    path: root.browse_path
                    filters: root.file_filters
                    on_selection: root.on_file_selected(self.selection)
                    multiselect: False

            BoxLayout:
                orientation: 'vertical'
                size_hint_x: 0.38
                spacing: dp(4)
                padding: dp(8)
                canvas.before:
                    Color:
                        rgba: (0.10, 0.12, 0.18, 0.5)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(14)]

                Label:
                    text: 'Target File'
                    size_hint_y: None
                    height: dp(20)
                    halign: 'center'
                    valign: 'center'
                    text_size: self.width, self.height
                    bold: True
                    font_size: '11sp'
                    color: (0.6, 0.65, 0.8, 1)

                Label:
                    text: os.path.basename(root.selected_file) if root.selected_file else 'None chosen'
                    halign: 'center'
                    valign: 'top'
                    text_size: self.width, self.height
                    shorten: True
                    shorten_from: 'center'
                    font_size: '10sp'
                    color: (0.75, 0.78, 0.85, 0.8)

                Button:
                    text: 'Play File'
                    size_hint_y: None
                    height: dp(36)
                    on_release: root.play_selected_file()
                    background_color: (0, 0, 0, 0)
                    bold: True
                    font_size: '12sp'
                    canvas.before:
                        Color:
                            rgba: (0.11, 0.31, 0.92, 1)
                        RoundedRectangle:
                            pos: self.pos
                            size: self.size
                            radius: [dp(8)]

        # Persistent App Switcher Tab bar
        NavBar:
            Button:
                text: 'Player Deck'
                background_color: (0, 0, 0, 0)
                on_release: root.manager.current = 'player_screen'
            Button:
                text: '● Search Hub'
                bold: True
                color: (0.2, 0.83, 0.61, 1)
                background_color: (0, 0, 0, 0)
                canvas.before:
                    Color:
                        rgba: (0.11, 0.31, 0.92, 0.4)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]
            Button:
                text: 'Developer'
                background_color: (0, 0, 0, 0)
                on_release: root.manager.current = 'developer_screen'


# =========================================================================
# INTERFACE 3: THE DEVELOPER SCREEN (Biography & Credentials)
# =========================================================================
<DeveloperScreen>:
    canvas.before:
        Color:
            rgba: (0.06, 0.07, 0.11, 1)
        Rectangle:
            size: self.size
            pos: self.pos
        Mesh:
            mode: 'triangle_fan'
            vertices:
                [
                self.x, self.y, 0, 0, 0.06, 0.07, 0.11, 1,
                self.right, self.y, 0, 0, 0.08, 0.12, 0.18, 1,
                self.right, self.top, 0, 0, 0.18, 0.12, 0.32, 1,
                self.x, self.top, 0, 0, 0.05, 0.22, 0.25, 1
                ]
            indices: [0, 1, 2, 3]

    BoxLayout:
        orientation: 'vertical'
        padding: dp(16)
        spacing: dp(14)

        BoxLayout:
            size_hint_y: None
            height: dp(44)
            canvas.before:
                Color:
                    rgba: (0.11, 0.31, 0.92, 0.8)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(12)]
            Label:
                text: 'Developer Credentials'
                halign: 'center'
                valign: 'center'
                text_size: self.width, self.height
                bold: True
                font_size: '15sp'
                color: (1, 1, 1, 1)

        # Profile Card Presentation Layout View
        BoxLayout:
            orientation: 'vertical'
            padding: dp(20)
            spacing: dp(12)
            canvas.before:
                Color:
                    rgba: (0.12, 0.15, 0.24, 0.45)
                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [dp(16)]

            Label:
                text: root.developer_name
                font_size: '20sp'
                bold: True
                color: (0.2, 0.83, 0.61, 1)
                size_hint_y: None
                height: dp(28)

            Label:
                text: root.developer_role
                font_size: '13sp'
                italic: True
                color: (0.7, 0.75, 0.9, 1)
                size_hint_y: None
                height: dp(20)

            # Elegant separator line asset
            Widget:
                size_hint_y: None
                height: dp(2)
                canvas.before:
                    Color:
                        rgba: (0.11, 0.31, 0.92, 0.5)
                    Rectangle:
                        pos: self.pos
                        size: self.size

            Label:
                text: root.developer_bio
                font_size: '13sp'
                color: (0.9, 0.92, 0.98, 1)
                text_size: self.width - dp(10), None
                halign: 'center'
                valign: 'top'

        Widget: # Dynamic layout layout spacer block

        # Persistent App Switcher Tab bar
        NavBar:
            Button:
                text: 'Player Deck'
                background_color: (0, 0, 0, 0)
                on_release: root.manager.current = 'player_screen'
            Button:
                text: 'Search Hub'
                background_color: (0, 0, 0, 0)
                on_release: root.manager.current = 'search_screen'
            Button:
                text: '● Developer'
                bold: True
                color: (0.2, 0.83, 0.61, 1)
                background_color: (0, 0, 0, 0)
                canvas.before:
                    Color:
                        rgba: (0.11, 0.31, 0.92, 0.4)
                    RoundedRectangle:
                        pos: self.pos
                        size: self.size
                        radius: [dp(10)]